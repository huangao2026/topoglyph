# 古文字破译系统 - 环境变量配置示例
# 复制此文件为 .env 并填入您的实际配置

# ========================================
# 必需的环境变量
# ========================================

# 工作空间路径
COZE_WORKSPACE_PATH=/workspace/projects

# Moonshot AI API Key（用于调用 Kimi K2.5 模型）
# 获取方式：https://platform.moonshot.cn/console/api-keys
COZE_WORKLOAD_IDENTITY_API_KEY=your_moonshot_api_key_here

# Moonshot AI API 基础 URL
COZE_INTEGRATION_MODEL_BASE_URL=https://api.moonshot.cn/v1

# ========================================
# 可选的环境变量
# ========================================

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# 最大消息数量（滑动窗口大小）
MAX_MESSAGES=40

# 服务端口
PORT=8000

# 服务主机地址
HOST=0.0.0.0

# 模型温度参数（0-1，越高越随机）
MODEL_TEMPERATURE=0.6

# 模型最大输出 Token 数
MAX_TOKENS=32768

# 请求超时时间（秒）
REQUEST_TIMEOUT=600

# ========================================
# 数据库配置（PostgreSQL）
# ========================================

# PostgreSQL 数据库用户名
DB_USER=ancienttext

# PostgreSQL 数据库密码（请修改为强密码）
DB_PASSWORD=your_strong_password_here

# PostgreSQL 数据库名称
DB_NAME=ancienttext

# PostgreSQL 数据库主机（Docker内部网络使用服务名）
DB_HOST=db

# PostgreSQL 数据库端口
DB_PORT=5432

# PostgreSQL 数据库连接URL（自动生成）
DATABASE_URL=postgresql://ancienttext:your_strong_password_here@db:5432/ancienttext

# 数据库连接池大小
DB_POOL_SIZE=10

# 数据池最大溢出连接数
DB_MAX_OVERFLOW=20

# 数据库连接超时时间（秒）
DB_TIMEOUT=30

# 数据库连接回收时间（秒）
DB_POOL_RECYCLE=3600

# ========================================
# Redis 缓存配置
# ========================================

# Redis 主机（Docker内部网络使用服务名）
REDIS_HOST=redis

# Redis 端口
REDIS_PORT=6379

# Redis 数据库编号
REDIS_DB=0

# Redis 密码（如需密码认证）
REDIS_PASSWORD=

# Redis 连接URL（自动生成）
REDIS_URL=redis://redis:6379/0

# Redis 最大连接数
REDIS_MAX_CONNECTIONS=50

# Redis 连接超时时间（秒）
REDIS_TIMEOUT=5

# Redis 缓存过期时间（秒，默认1小时）
REDIS_CACHE_TTL=3600

# ========================================
# 对象存储配置（可选，用于文件存储）
# ========================================

# S3 兼容存储配置
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=ancient-script-bucket
# S3_REGION=us-east-1

# ========================================
# 监控配置（可选）
# ========================================

# Prometheus 配置
# PROMETHEUS_PORT=9090

# Grafana 配置
# GRAFANA_PORT=3000

# ========================================
# 安全配置（可选）
# ========================================

# JWT Secret（用于 API 认证）
# JWT_SECRET=your_jwt_secret_here

# API Key（用于外部 API 访问）
# API_KEY=your_api_key_here

# CORS 允许的源（多个用逗号分隔）
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ========================================
# 邮件通知配置（可选）
# ========================================

# SMTP 配置
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_email_password
# SMTP_FROM=your_email@gmail.com

# ========================================
# 开发配置（仅开发环境使用）
# ========================================

# 开发模式（启用调试和自动重载）
# DEVELOPMENT_MODE=true

# 启用 API 文档
# ENABLE_DOCS=true

# 启用 CORS 调试
# CORS_DEBUG=false
