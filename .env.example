# ===== API配置 =====
# Coze API Key（必填）
COZE_WORKLOAD_IDENTITY_API_KEY=your_api_key_here

# Coze Base URL（必填）
COZE_INTEGRATION_MODEL_BASE_URL=your_base_url_here

# ===== 应用配置 =====
# 工作空间路径
COZE_WORKSPACE_PATH=/app

# 密钥（用于会话管理）
SECRET_KEY=your_secret_key_change_this_in_production

# 允许的跨域来源（逗号分隔）
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===== 数据库配置（可选）=====
DATABASE_URL=postgresql://ancienttext:your_password@db:5432/ancienttext
DB_USER=ancienttext
DB_PASSWORD=your_strong_password_here
DB_NAME=ancienttext

# ===== Redis配置（可选）=====
REDIS_URL=redis://redis:6379/0

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FILE=/app/work/logs/bypass/app.log

# ===== 安全配置 =====
# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10

# ===== 上传配置 =====
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/tiff

# ===== 环境标识 =====
ENVIRONMENT=development
DEBUG=false
